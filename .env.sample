# --- Claude API -----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Optional
# TAILOR_MODEL=claude-sonnet-4-6
# EXTRACT_MODEL=claude-haiku-4-5-20251001

# --- Web app --------------------------------------------------------------
# Long random string. Rotate to force-logout everyone.
SESSION_SECRET=replace-me-with-a-long-random-string

# Email that becomes the sole admin on server boot.
ADMIN_EMAIL=you@example.com

# Used to build magic-link URLs in emails.
APP_BASE_URL=http://127.0.0.1:8000

# --- Email (magic-link) ---------------------------------------------------
# Leave SMTP_HOST blank during local dev — magic links are printed to the
# server console so you can paste them into the browser.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
